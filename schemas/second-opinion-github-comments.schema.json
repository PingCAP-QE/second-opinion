{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["repo_url", "comments"],
  "properties": {
    "repo_url": {
      "const": "https://github.com/PingCAP-QE/second-opinion"
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mode",
          "body",
          "source",
          "severity",
          "attribution_line"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["inline", "file", "general"]
          },
          "path": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "object",
            "required": ["type", "id"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["rule", "process", "policy"]
              },
              "id": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "attribution_line": {
            "type": "string",
            "pattern": "^Source: (rule|process|policy)/[^|]+ \\| \\[Second Opinion\\]\\(https://github\\.com/PingCAP-QE/second-opinion\\)$"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {"mode": {"const": "inline"}},
              "required": ["mode"]
            },
            "then": {
              "required": ["path", "line"]
            }
          },
          {
            "if": {
              "properties": {"mode": {"const": "file"}},
              "required": ["mode"]
            },
            "then": {
              "required": ["path"]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
